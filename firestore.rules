rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sofaaa163@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidTip(data) {
      return data.content is string && data.content.size() <= 500 &&
             data.createdAt == request.time &&
             data.author is string && 
             data.author.matches('^[a-z]+\\.[a-z]+$') &&
             data.approved == false;
    }

    match /tips/{tipId} {
      // Allow everyone to list approved tips
      allow list: if resource.data.approved == true || isAdmin();
      allow get: if isValidId(tipId) && (resource.data.approved == true || isAdmin());
      
      // Allow creation only if data is valid and initialized as NOT approved
      allow create: if isValidId(tipId) && isValidTip(request.resource.data);

      // Only admin can approve or delete tips
      allow update: if isAdmin() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approved']);
      
      allow delete: if isAdmin();
    }

    match /stats/{docId} {
      allow read: if true;
      allow update: if docId == 'counters' && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalVisits']) &&
                    request.resource.data.totalVisits == resource.data.totalVisits + 1;
    }

    match /presence/{sessionId} {
      allow list: if true;
      allow get: if isValidId(sessionId);
      allow write: if isValidId(sessionId) && 
                   request.resource.data.keys().hasAll(['lastSeen']) &&
                   request.resource.data.lastSeen == request.time;
    }

    // Admins collection
    match /admins/{userId} {
      allow read: if isSignedIn();
    }
  }
}
