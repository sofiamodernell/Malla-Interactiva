{
  "entities": {
    "Tip": {
      "title": "Student Tip",
      "description": "A piece of advice left by a student for a specific subject.",
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "The tip content"
        },
        "author": {
          "type": "string",
          "description": "Name or handle of the student"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the tip was created"
        },
        "approved": {
          "type": "boolean",
          "description": "Whether the tip has been approved by an authorized user"
        }
      },
      "required": ["content", "createdAt", "approved"]
    },
    "Stats": {
      "title": "Application Stats",
      "description": "Global statistics for the application.",
      "type": "object",
      "properties": {
        "totalVisits": {
          "type": "number",
          "description": "The total number of page visits"
        }
      },
      "required": ["totalVisits"]
    },
    "Presence": {
      "title": "User Presence",
      "description": "Real-time presence record for an active user session.",
      "type": "object",
      "properties": {
        "lastSeen": {
          "type": "string",
          "format": "date-time",
          "description": "The last time this session was active"
        }
      },
      "required": ["lastSeen"]
    }
  },
  "firestore": {
    "/tips/{tipId}": {
      "schema": "Tip",
      "description": "General collection of student tips"
    },
    "/stats/counters": {
      "schema": "Stats",
      "description": "Global counters"
    },
    "/presence/{sessionId}": {
      "schema": "Presence",
      "description": "Active user sessions"
    }
  }
}
